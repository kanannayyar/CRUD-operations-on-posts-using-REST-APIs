<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Edit post</h1>
    <h3>Post id: <%= post.id %> </h3>
    <h3>Username: <%= post.username %></h3>
    <br>
    <form method="post" action="/posts/<%= post.id %>?_method=PATCH" >          <!--query string to convert post request to patch request-->
    <textarea placeholder="Enter new content" name="content"><%=post.content%></textarea>
    <button>Add changes</button>
    </form>
</body>
</html>