<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- to view a particular post -->
     <h2>Here is your post in detail</h2>
    <div class="post">
         <h3 class="id">Post id: <%=post.id%></h3>
         <h3 class="user"> @<%= post.username %> </h3>
         <h4 class="content"> <%= post.content %> </h4>
    </div>
    <a href="http://localhost:8080/posts">Back to all posts</a>
    
</body>
</html>