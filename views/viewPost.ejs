<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6">
    <!-- to view a particular post -->
     <h2 class="text-3xl font-bold text-center mb-6">Here is your post in detail</h2>
    <div class="bg-white p-5 rounded-2xl shadow-md hover:shadow-lg transition">
         <h3 class="text-sm text-gray-500 mb-2">Post id: <%=post.id%></h3>
         <h3 class="text-sm text-gray-500 mb-2"> @<%= post.username %> </h3>
         <h4 class="text-lg font-medium text-gray-800 mb-4"> <%= post.content %> </h4>
    </div>
    <br>
    <div class="flex justify-center mb-6">
     <a href="http://localhost:8080/posts" class="bg-blue-500 text-white px-5 py-2 rounded-xl hover:bg-blue-600 shadow">Back to all posts</a>
    </div>
    
</body>
</html>